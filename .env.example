ANTHROPIC_API_KEY=
SWIGGY_MCP_API_KEY=
SWIGGY_MCP_BASE_URL=https://mcp.swiggy.com/food

# Use mock Swiggy data when key is missing (default: auto-detect)
USE_SWIGGY_MOCK=true

# Set true only when Swiggy access works and you want real orders
ENABLE_REAL_ORDERS=false

# Optional: override Claude model
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Show demo banner in UI
NEXT_PUBLIC_DEMO_MODE=true
